# CareSuite+ — Umgebungsvariablen (Beispiel, keine Secrets committen)
# Pilot-Deployment: Datei als `.env` kopieren und Werte eintragen.

# --- Supabase (Frontend: nur Anon/Publishable Key, niemals service_role) ---
# Projekt-URL aus Supabase Dashboard → Settings → API
EXPO_PUBLIC_SUPABASE_URL=
# Publishable/Anon Key — nur für Client-App, nicht für Server-Secrets
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# --- Auth-Redirects (Passwort-Reset, E-Mail-Links) ---
# Lokal: http://localhost:8082  (Port ggf. anpassen)
# Produktion: https://<ihre-domain>  (muss in Supabase → Auth → URL Configuration eingetragen sein)
EXPO_PUBLIC_AUTH_REDIRECT_URL=http://localhost:8082

# true  = Demo-Login + In-Memory-Daten (Standard wenn URL fehlt)
# false = Live-Supabase: Passwort-Login, RLS, kein DEMO_TENANT_ID-Fallback
EXPO_PUBLIC_DEMO_MODE=true

# --- Live-Pilot (EXPO_PUBLIC_DEMO_MODE=false) ---
# EXPO_PUBLIC_DEMO_MODE=false
# EXPO_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
# EXPO_PUBLIC_SUPABASE_ANON_KEY=<anon-key>
#
# Voraussetzungen:
# - Migrationen 0001–0014 per `supabase db push` (lokal oder Remote)
# - Mandanten + Auth-User + profile.tenant_id gesetzt
# - Kein service_role im Frontend
#
# Typen generieren (Remote, nur mit Zugangsdaten):
#   npx supabase login
#   npx supabase link --project-ref <ref>
#   npx supabase gen types typescript --linked > src/lib/supabase/types.ts
#
# Quality Gates:
#   npm run typecheck && npm run test && npm run smoke
#   npm run platform:audit && npm run store:audit

# --- EAS Build (optional, für eas build / submit) ---
# UUID aus `npx eas project:init` — nicht erfinden
# EAS_PROJECT_ID=
# APP_ENV wird durch eas.json Profile gesetzt (development|preview|production)
