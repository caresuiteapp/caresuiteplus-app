# --- Kartenansicht (optional) ---
# OpenStreetMap ist Standard — kein Key nötig.
# Optional: Mapbox für erweiterte Kartenkacheln
# EXPO_PUBLIC_MAPBOX_ACCESS_TOKEN=
# MAPBOX_ACCESS_TOKEN=

# --- Google Maps Fahrzeit (serverseitig) ---
# Supabase Edge Function Secret (Dashboard → Edge Functions → Secrets):
# GOOGLE_MAPS_API_KEY=
# Optional/reserviert für spätere Kartenkacheln (Travel Time nutzt nur die Edge Function):
# EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=
