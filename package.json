{
  "name": "caresuite-plus",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "typecheck": "tsc --noEmit",
    "regenerate-router-types": "node scripts/regenerate-router-types.mjs",
    "check": "npm run typecheck",
    "smoke": "node scripts/smoke-check.mjs",
    "deploy:live-pilot": "node scripts/deploy-live-pilot.mjs",
    "apply:live-migrations": "node scripts/apply-live-migrations.mjs",
    "seed:live-pilot": "node scripts/seed-live-pilot.mjs --write-sql",
    "fetch-remote-types": "node scripts/fetch-remote-types.mjs",
    "test": "vitest run",
    "wp-m-verify": "node scripts/wp-m-verify.mjs",
    "generate-m-wp": "node scripts/generate-m-wp-deliverables.mjs",
    "platform:audit": "node scripts/platform-audit.mjs",
    "store:audit": "node scripts/store-audit.mjs",
    "free-platform:audit": "node scripts/free-platform-audit.mjs",
    "design:audit": "node scripts/design-audit.mjs",
    "audit:no-white": "node scripts/audit-no-white-backgrounds.js",
    "audit:runtime-backgrounds": "node scripts/audit-runtime-backgrounds.mjs",
    "eas:preflight": "node scripts/eas-preflight.mjs",
    "responsive:audit": "node scripts/responsive-audit.mjs",
    "content:audit": "node scripts/content-architecture-audit.mjs",
    "prepared-only:audit": "node scripts/prepared-only-audit.mjs",
    "visual:audit": "node scripts/visual-reality-audit.mjs",
    "office:terminology:audit": "node scripts/office-terminology-audit.mjs",
    "client-intake:audit": "node scripts/client-intake-audit.mjs",
    "locale:audit": "node scripts/locale-format-audit.mjs",
    "catalog:audit": "node scripts/catalog-audit.mjs",
    "einzelseiten:audit": "node scripts/einzelseiten-route-audit.mjs",
    "extension-blocks:extract": "node scripts/extract-extension-blocks.mjs",
    "extension-blocks:audit": "node scripts/extension-blocks-audit.mjs",
    "arbeitsplan:audit": "node scripts/arbeitsplan-route-audit.mjs",
    "navigation:audit": "node scripts/navigation-duplicate-audit.mjs",
    "functional:audit": "node scripts/functional-reality-audit.mjs",
    "einzelseiten:generate": "node scripts/extract-einzelseiten-routes.mjs && node scripts/generate-einzelseiten-bridges.mjs",
    "audit:p0-series-reset": "node scripts/audit/p0SeriesOccurrenceExecutionReset.mjs",
    "audit:p0-series-reset:write": "node scripts/audit/p0SeriesOccurrenceExecutionReset.mjs --write",
    "audit:p0-series-debug": "node scripts/audit/debugSeriesOccurrenceStatusSource.mjs",
    "audit:p0-series-local-acceptance": "node scripts/audit/p0SeriesOccurrenceLocalAcceptance.mjs"
  },
  "dependencies": {
    "@expo/metro-runtime": "~4.0.1",
    "@opentelemetry/api": "^1.9.1",
    "@react-native-async-storage/async-storage": "1.23.1",
    "@supabase/phoenix": "^0.4.4",
    "@supabase/supabase-js": "^2.49.0",
    "expo": "~52.0.46",
    "expo-asset": "~11.0.5",
    "expo-av": "~15.0.2",
    "expo-blur": "~14.0.3",
    "expo-build-properties": "~0.13.3",
    "expo-constants": "~17.0.8",
    "expo-document-picker": "~13.0.3",
    "expo-font": "~13.0.4",
    "expo-linear-gradient": "~14.0.2",
    "expo-linking": "~7.0.5",
    "expo-location": "~18.0.10",
    "expo-router": "~4.0.20",
    "expo-status-bar": "~2.0.1",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-native": "0.76.9",
    "react-native-reanimated": "~3.16.1",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "react-native-url-polyfill": "^2.0.0",
    "react-native-web": "~0.19.13",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@expo/ngrok": "^4.1.3",
    "@resvg/resvg-js": "^2.6.2",
    "@types/react": "~18.3.12",
    "eslint": "^8.57.0",
    "eslint-config-expo": "~8.0.1",
    "playwright": "^1.49.1",
    "typescript": "~5.3.3",
    "vitest": "^3.2.6"
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "expo-av",
          "@opentelemetry/api",
          "html2canvas",
          "jspdf"
        ]
      }
    }
  }
}
